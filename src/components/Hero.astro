---
import type { SiteContent } from '../i18n/types'
import { links } from '../i18n/types'

interface Props {
  content: SiteContent
}

const { content } = Astro.props
const docsUrl = content.locale === 'zh' ? links.helpZh : links.helpEn
const titleLines = content.hero.title.split('\n')
const base = import.meta.env.BASE_URL
---

<section class="hero">
  <div class="hero-glow" aria-hidden="true"></div>
  <div class="container hero-inner">
    <p class="badge">{content.hero.badge}</p>
    <h1>
      {titleLines.map((line) => (
        <span class="title-line">{line}</span>
      ))}
    </h1>
    <p class="subtitle">{content.hero.subtitle}</p>
    <div class="cta-row">
      <a class="btn btn-primary" href={links.releases} target="_blank" rel="noopener noreferrer">
        {content.hero.ctaDownload}
      </a>
      <a class="btn btn-secondary" href={links.extRepo} target="_blank" rel="noopener noreferrer">
        {content.hero.ctaExtension}
      </a>
      <a class="btn btn-secondary" href={docsUrl} target="_blank" rel="noopener noreferrer">
        {content.hero.ctaDocs}
      </a>
    </div>
    <p class="note">{content.hero.note}</p>

    <div class="hero-screenshots">
      <figure class="screenshot-card">
        <img
          src={`${base}hero-screenshot-light_ui.png`}
          alt={content.hero.screenshotLightAlt}
          width="1280"
          height="720"
          loading="lazy"
          decoding="async"
        />
      </figure>
      <figure class="screenshot-card">
        <img
          src={`${base}hero-screenshot-dark_ui.png`}
          alt={content.hero.screenshotDarkAlt}
          width="1280"
          height="720"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 4.5rem 0 2rem;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    inset: -20% 10% auto;
    height: 420px;
    background: radial-gradient(ellipse at center, rgba(61, 126, 255, 0.18), transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
  }

  .badge {
    display: inline-block;
    margin: 0 0 1rem;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    background: var(--accent-soft);
    color: #9ec0ff;
    font-size: 0.82rem;
    font-family: var(--font-mono);
  }

  h1 {
    margin: 0 0 1rem;
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1.2;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  .title-line {
    display: block;
  }

  /* Keep manual line breaks only; avoid mid-phrase wraps on wider screens */
  @media (min-width: 640px) {
    .title-line {
      white-space: nowrap;
    }
  }

  .subtitle {
    margin: 0 0 1.75rem;
    color: var(--text-muted);
    font-size: clamp(1rem, 2.2vw, 1.15rem);
    max-width: 42rem;
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .note {
    margin: 0 0 2rem;
    color: var(--text-muted);
    font-size: 0.88rem;
    max-width: 40rem;
  }

  .hero-screenshots {
    display: grid;
    gap: 1rem;
    max-width: 1120px;
  }

  @media (min-width: 900px) {
    .hero-screenshots {
      grid-template-columns: 1fr 1fr;
    }
  }

  .screenshot-card {
    margin: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg-card);
    box-shadow: var(--shadow);
  }

  .screenshot-card img {
    display: block;
    width: 100%;
    height: auto;
    vertical-align: middle;
  }
</style>
